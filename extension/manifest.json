{
  "manifest_version": 3,
  "name": "Vantage AutoFill",
  "version": "1.0.0",
  "description": "Auto-fill scholarship forms using your Vantage profile.",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup/index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content/content.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
